# Backend (server/) - copy to .env and fill to drive the REAL Nexi test API.
# Leave unset to run the bundled sandbox (no merchant account needed).

# Secret API key from the Nexi/Nets test portal (server-side only, never in app).
NEXI_SECRET_KEY=
# Checkout key (public) used by the Checkout JS SDK in the browser/WebView.
NEXI_CHECKOUT_KEY=
# Optional overrides.
NEXI_API_BASE=https://test.api.dibspayment.eu
NEXI_CHECKOUT_JS=https://test.checkout.dibspayment.eu/v1/checkout.js?v=1
# Public URL of this backend (for the Nexi return/redirect when keyed).
PUBLIC_URL=http://localhost:3000

# App (Expo) - set when running on a physical device so it can reach the backend.
# EXPO_PUBLIC_API_BASE=http://192.168.1.50:3000
